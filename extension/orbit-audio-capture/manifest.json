{
  "manifest_version": 3,
  "name": "Orbit Meet Audio Capture",
  "version": "0.1.0",
  "description": "Captures Google Meet tab audio for Orbit live transcription.",
  "permissions": [
    "activeTab",
    "offscreen",
    "scripting",
    "storage",
    "tabCapture",
    "tabs"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "ws://127.0.0.1:*/*",
    "ws://localhost:*/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Start Orbit audio capture"
  },
  "commands": {
    "start-capture": {
      "suggested_key": {
        "default": "Alt+Shift+O"
      },
      "description": "Start Orbit tab audio capture"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://127.0.0.1:* ws://localhost:*"
  }
}
