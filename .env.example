GMEET_URL=https://meet.google.com/your-meeting-code
GMEET_DISPLAY_NAME=Orbit
GMEET_WAIT_AFTER_JOIN_MS=300000
GMEET_USE_SYSTEM_CHROME=false
GMEET_CHROME_PROFILE_DIRECTORY=Default
GMEET_BROWSER_USE_MAX_STEPS=20
HEADLESS=false

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_LIVE_MODEL=nova-3
ORBIT_LIVE_STT_ENABLED=true
ORBIT_AUDIO_WS_BASE_URL=ws://127.0.0.1:8000
ORBIT_CHROME_EXTENSION_PATH=extension/orbit-audio-capture
ORBIT_CHROME_CDP_URL=
ORBIT_EXTENSION_CAPTURE_SHORTCUT=Alt+Shift+O

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+15551234567
TWILIO_ALLOWED_FROM=whatsapp:+15551234567

ORBIT_WEBHOOK_HOST=0.0.0.0
ORBIT_WEBHOOK_PORT=8000
ORBIT_MAX_PARALLEL_MEETINGS=3
ORBIT_ORGANIZATION_ID=default
ORBIT_MEMORY_SEARCH_LIMIT=6
ORBIT_MEMORY_SIMILARITY_THRESHOLD=0.35

DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbit
